FLASK_SECRET_KEY=replace-me
APP_BASE_URL=http://127.0.0.1:5000

LASTFM_API_KEY=your-lastfm-api-key
LASTFM_USERNAME=your-lastfm-username

GENIUS_ACCESS_TOKEN=your-genius-access-token

LRCLIB_API_URL=https://lrclib.net/api

TRANSLATION_PROVIDER=deepl
TRANSLATION_SOURCE_LANG=auto
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
TRANSLATION_CACHE_PATH=.cache/translations.sqlite3
LANGUAGE_CONFIDENCE_THRESHOLD=0.72
LANGUAGE_SHORT_LINE_CHARS=12
SPOTIFY_TRANSLATION_PAUSE_WINDOW_SECONDS=12
MYMEMORY_API_URL=https://api.mymemory.translated.net/get
MYMEMORY_EMAIL=
